{
  "name": "@plaidly/node",
  "version": "0.1.0",
  "description": "Official Plaidly Node.js / TypeScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
