            ],
            "url": { "raw": "{{base_url}}/v1/merchants", "host": ["{{base_url}}"], "path": ["v1", "merchants"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"payments@acme.com\",\n  \"webhook_url\": \"https://acme.com/webhooks/plaidly\",\n  \"sandbox\": false\n}"
            }
