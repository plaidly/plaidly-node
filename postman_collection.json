              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"mer_01HZX\",\n  \"name\": \"Acme Corp\",\n  \"email\": \"payments@acme.com\",\n  \"apiKey\": \"pk_live_abc123\",\n  \"webhookUrl\": \"https://acme.com/webhooks/plaidly\",\n  \"sandbox\": false,\n  \"createdAt\": \"2026-04-19T10:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Get Current Merchant",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}", "type": "text" }
            ],
            "url": { "raw": "{{base_url}}/v1/me", "host": ["{{base_url}}"], "path": ["v1", "me"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"mer_01HZX\",\n  \"name\": \"Acme Corp\",\n  \"email\": \"payments@acme.com\",\n  \"apiKey\": \"pk_live_abc123\",\n  \"webhookUrl\": \"https://acme.com/webhooks/plaidly\",\n  \"sandbox\": false,\n  \"createdAt\": \"2026-04-19T10:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
